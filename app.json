{
  "expo": {
    "name": "TopSeller AI",
    "slug": "topseller-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "topsellerai",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFDF9"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.topseller.ai",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "TopSeller AI ต้องการเข้าถึงรูปภาพเพื่อแต่งรูปสินค้า",
        "NSCameraUsageDescription": "TopSeller AI ต้องการกล้องเพื่อถ่ายรูปสินค้า"
      }
    },
    "android": {
      "package": "com.topseller.ai",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EA580C"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-splash-screen",
      [
        "expo-image-picker",
        {
          "photosPermission": "TopSeller AI ต้องการเข้าถึงรูปภาพเพื่อแต่งรูปสินค้า",
          "cameraPermission": "TopSeller AI ต้องการกล้องเพื่อถ่ายรูปสินค้า"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "replace-with-sentry-org",
          "project": "topseller-ai"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "replace-with-your-eas-project-id"
      }
    }
  }
}
