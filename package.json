{
  "name": "topseller-ai",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterFramework": [],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/.*|@shopify/.*|sentry-expo|native-base|react-native-svg)"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.14.14",
    "@sentry/react-native": "^8.11.0",
    "@shopify/react-native-skia": "^2.4.18",
    "@six33/react-native-bg-removal": "^1.3.2",
    "@supabase/supabase-js": "^2.57.4",
    "@testing-library/react-native": "^13.3.3",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~55.0.15",
    "expo-apple-authentication": "^55.0.13",
    "expo-dev-client": "~55.0.14",
    "expo-file-system": "^55.0.19",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.16",
    "expo-linear-gradient": "~55.0.13",
    "expo-network": "^55.0.13",
    "expo-sharing": "~55.0.11",
    "expo-splash-screen": "^55.0.20",
    "expo-status-bar": "~55.0.5",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.17",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-purchases": "^9.5.1",
    "react-native-purchases-ui": "^9.5.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "^4.24.0",
    "react-native-url-polyfill": "^3.0.0",
